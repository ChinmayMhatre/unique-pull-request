# --- Shared Configuration (Required by both Bot and Audit) ---
# Use `trace` to get verbose logging or `info` to show less
LOG_LEVEL=debug

# Gemini API Key (from https://aistudio.google.com/)
GEMINI_API_KEY=

# Groq API Key (from https://console.groq.com/)
GROQ_API_KEY=

# Upstash Vector DB Credentials (from https://console.upstash.com/)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# --- Bot Specific Configuration (Required for live triage) ---
# The ID of your GitHub App
APP_ID=
# The Client ID of your GitHub App
GITHUB_CLIENT_ID=
# The Client Secret of your GitHub App
GITHUB_CLIENT_SECRET=
# The Webhook Secret (defined during app setup)
WEBHOOK_SECRET=development
# The Private Key (generated in app settings, include newlines as \n)
PRIVATE_KEY=
# Go to https://smee.io/new set this to the URL that you are redirected to.
WEBHOOK_PROXY_URL=

# --- Audit Specific Configuration (Required for historical scanning) ---
# Personal Access Token (for the Audit tool)
GITHUB_TOKEN=
